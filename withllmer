import pyspark.sql.functions as F

# 1. Load the raw candidate tables
TABLE_ORG = "dev.mma_entityresolution.tbl_entityres_ach_org_names_match"
TABLE_REC = "dev.mma_entityresolution.tbl_entityres_ach_rec_names_match"

df_org = spark.table(TABLE_ORG).withColumn("role_type", F.lit("ACH_ORIGINATION"))
df_rec = spark.table(TABLE_REC).withColumn("role_type", F.lit("ACH_RECEIVED"))

# 2. Rename columns to a standard 'src_company_name_raw' for the pipeline
df_org = df_org.withColumnRenamed("originator_company_name", "src_company_name_raw")
df_rec = df_rec.withColumnRenamed("dest_customer_nm", "src_company_name_raw")

print(f"Loaded {df_org.count()} Orgs and {df_rec.count()} Receivers.")




def apply_name_repair(df):
    return df.withColumn("src_company_name_normalized", 
        F.upper(F.col("src_company_name_raw"))) \
        .withColumn("src_company_name_normalized", F.regexp_replace("src_company_name_normalized", r"[^\w\s]", "")) \
        .withColumn("src_company_name_normalized", F.regexp_replace("src_company_name_normalized", r"\b(CORP|CO|INC|LLC|LTD)\b", "")) \
        .withColumn("src_company_name_normalized", F.trim(F.col("src_company_name_normalized")))

df_org_clean = apply_name_repair(df_org)
df_rec_clean = apply_name_repair(df_rec)

# Create the Search Registry (Unique names only to save API costs)
search_registry = df_org_clean.select("src_company_name_normalized") \
    .union(df_rec_clean.select("src_company_name_normalized")) \
    .distinct().filter("src_company_name_normalized != ''")






from databricks.vector_search.client import VectorSearchClient
import pandas as pd
from pyspark.sql.types import *

result_schema = StructType([
    StructField("src_company_name_normalized", StringType(), True),
    StructField("childcompanyname", StringType(), True),
    StructField("childcompanyid", StringType(), True),
    StructField("companytypename", StringType(), True),
    StructField("match_confidence_score", FloatType(), True),
    StructField("top2_score", FloatType(), True)
])

def search_vector_worker(iterator):
    vsc = VectorSearchClient()
    index = vsc.get_index(endpoint_name="talk2db_poc_endpoint", 
                         index_name="dev.er_sp_metadata.spg_entity_master_index")
    for pdf in iterator:
        results = []
        for name in pdf['src_company_name_normalized']:
            try:
                resp = index.similarity_search(query_text=name, 
                                             columns=["childcompanyid", "childcompanyname", "companytypename"], 
                                             num_results=2)
                data = resp.get('result', {}).get('data_array', [])
                if data:
                    top1 = data[0]
                    t2_score = float(data[1][3]) * 100 if len(data) > 1 else 0.0
                    results.append({"src_company_name_normalized": name, "childcompanyname": str(top1[1]), 
                                    "childcompanyid": str(top1[0]), "companytypename": str(top1[2]), 
                                    "match_confidence_score": float(top1[3]) * 100, "top2_score": t2_score})
                else:
                    results.append({"src_company_name_normalized": name, "childcompanyname": None, "childcompanyid": None, "companytypename": None, "match_confidence_score": 0.0, "top2_score": 0.0})
            except:
                results.append({"src_company_name_normalized": name, "childcompanyname": "ERROR", "childcompanyid": None, "companytypename": None, "match_confidence_score": 0.0, "top2_score": 0.0})
        yield pd.DataFrame(results)

# Run search and cache to memory
final_matches_registry = search_registry.repartition(20).mapInPandas(search_vector_worker, schema=result_schema).cache()






# Join matches back to Source and Destination
df_final_org = df_org_clean.join(final_matches_registry, on="src_company_name_normalized", how="left")
df_final_rec = df_rec_clean.join(final_matches_registry, on="src_company_name_normalized", how="left")

# Define Reasoning Prompt
prompt_template = """
Act as a financial data auditor. 
Source Name: {src_name}
S&P Match: {sp_name} (Type: {sp_type})

Does the source name reasonably represent this S&P entity? 
Explain the relationship in one short sentence. If it's a poor match, start with 'Invalid'.
Explanation:"""

# Use ai_query for the LLM "Judge"
df_final_org = df_final_org.withColumn("match_explanation", 
    F.expr(f"ai_query('databricks-meta-llama-3-70b-instruct', format('{prompt_template}', src_company_name_raw, childcompanyname, companytypename))"))

# Final Decision Rules (Step 6)
df_final_org = df_final_org.withColumn("match_level", 
    F.when(F.col("match_explanation").contains("Invalid"), "UNMATCHED")
     .when(F.col("match_confidence_score") >= 92, "CHILD")
     .otherwise("PARENT"))






df_final_org.write.format("delta").mode("overwrite") \
    .saveAsTable("dev.mma_entityresolution.entity_resolution_ach_origination")

print("Pipeline Complete. Files stored and LLM Reasoning applied.")





