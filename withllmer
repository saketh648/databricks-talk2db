import pandas as pd
import pyspark.sql.functions as F
from pyspark.sql.types import *
from databricks.vector_search.client import VectorSearchClient

# --- STEP 0: RESET CACHE ---
spark.catalog.clearCache()

# --- STEP 1: PURE ENTITY EXTRACTION ---
def heavy_duty_clean(df, name_col):
    return df.withColumn("name_clean", 
        F.initcap(F.trim(
            # 1. Strip leading # followed by any digits or letters (e.g. #785946 or #BUE)
            # 2. Strip any leading digits alone (e.g. 1291RA0923)
            # 3. Strip trailing junk like 'DEFAULT' or 'LLC' for searching purposes
            F.regexp_replace(
                F.regexp_replace(F.upper(F.col(name_col)), r"^(#[A-Z0-9]+\s+|[0-9]+\s+)", ""), 
                r"[^\w\s]", ""
            )
        ))
    )

df_org = heavy_duty_clean(spark.table("dev.mma_entityresolution.tbl_entityres_ach_org_names_match").withColumnRenamed("sor_id0", "sor_id"), "originator_company_name")
df_rec = heavy_duty_clean(spark.table("dev.mma_entityresolution.tbl_entityres_ach_rec_names_match"), "dest_customer_nm")

# --- STEP 2: DYNAMIC VECTOR SEARCH ---
result_schema = StructType([
    StructField("name_clean", StringType(), True),
    StructField("candidates_json", StringType(), True),
    StructField("match_confidence_score", FloatType(), True)
])

def search_vector_worker_v6(iterator):
    import json
    vsc = VectorSearchClient()
    index = vsc.get_index(endpoint_name="talk2db_poc_endpoint", index_name="dev.er_sp_metadata.spg_entity_master_index")
    for pdf in iterator:
        results = []
        for name in pdf['name_clean']:
            try:
                # We pull 15 candidates now. With noisy data, the real match is often buried.
                resp = index.similarity_search(query_text=name, num_results=15)
                data = resp.get('result', {}).get('data_array', [])
                
                # Boost logic: If a candidate name contains the FIRST WORD of our clean input
                # (e.g. 'Compsource' from '#1001965 COMPSOURCE'), we rank it #1.
                first_word = name.split()[0].upper() if name else ""
                processed = []
                for r in data:
                    c_name = str(r[1])
                    v_score = float(r[-1]) * 100
                    boost = 1.3 if first_word and first_word in c_name.upper() else 1.0
                    processed.append({"name": c_name, "score": round(v_score * boost, 2)})
                
                sorted_p = sorted(processed, key=lambda x: x['score'], reverse=True)
                results.append({"name_clean": name, "candidates_json": json.dumps(sorted_p[:5]), "match_confidence_score": sorted_p[0]['score']})
            except:
                results.append({"name_clean": name, "candidates_json": "[]", "match_confidence_score": 0.0})
        yield pd.DataFrame(results)

search_registry = df_org.select("name_clean").union(df_rec.select("name_clean")).distinct()
registry_matches = search_registry.repartition(40).mapInPandas(search_vector_worker_v6, schema=result_schema).cache()

# --- STEP 3: REASONING LAYER ---
prompt_logic = """
format_string(
    "### ROLE: Expert Auditor. 
     INPUT: '%s' | CANDIDATES: %s.
     TASK: Find the real legal entity. 
     RULES: Ignore transaction codes/numbers. If the company is clearly 'Compsource' or 'Velocity', pick the global parent.
     FORMAT: [MATCH]: <name> | [REASON]: <short reason>", 
    name_clean, candidates_json
)
"""

# We lower threshold slightly to 65 to catch these noisy but valid records
answer_key = registry_matches.filter("match_confidence_score >= 65").repartition(100).withColumn("llm_raw", 
    F.expr(f"ai_query('databricks-llama-4-maverick', {prompt_logic}, map('max_tokens', '100', 'concurrency', '20'))")
).cache()

# --- STEP 4: FINAL ASSEMBLY ---
def finalize_and_save(df_clean, target_table):
    df_final = df_clean.join(registry_matches, on="name_clean", how="left") \
                       .join(answer_key.select("name_clean", "llm_raw"), on="name_clean", how="left")
    
    df_final = df_final.withColumn("childcompanyname", 
        F.when(F.col("match_confidence_score") < 65, F.lit("No Clear Match"))
         .otherwise(F.regexp_replace(F.regexp_extract("llm_raw", r"\[MATCH\]:\s*([^|]+)", 1), r"[\*\[\]]", ""))) \
                       .withColumn("match_explanation", 
        F.when(F.col("match_confidence_score") < 65, F.lit("No confident candidates found in master registry."))
         .otherwise(F.regexp_extract("llm_raw", r"\[REASON\]:\s*(.*)", 1)))

    df_final.select("sor_id", "src_company_name_raw", "childcompanyname", "match_explanation") \
            .write.format("delta").mode("overwrite").option("overwriteSchema", "true") \
            .saveAsTable(f"dev.mma_entityresolution.{target_table}")

finalize_and_save(df_org, "entity_resolution_ach_origination_llm")
finalize_and_save(df_rec, "entity_resolution_ach_received_llm")
