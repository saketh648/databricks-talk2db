import pandas as pd
import pyspark.sql.functions as F
from pyspark.sql.types import *
from databricks.vector_search.client import VectorSearchClient

# --- STEP 1: CLEANING (Explicitly defining src_company_name_raw) ---
def ultra_clean(df, name_col):
    # This line ensures the original column name exists throughout the pipeline
    return df.withColumn("src_company_name_raw", F.col(name_col)) \
             .withColumn("name_clean", 
        F.initcap(F.trim(
            F.regexp_replace(
                F.regexp_replace(F.upper(F.col(name_col)), r"^(#[A-Z0-9]+\s+|[0-9]+\s+|[0-9]+[A-Z]+\s+)", ""), 
                r"(?i)\b(DEFAULT|LLC|INC|CORP|LTD|SERVICES|S.P.A|B.V|K.K)\b", ""
            )
        ))
    )

# Force clear cache to reset the schema in Spark's memory
spark.catalog.clearCache()

# Ingest and Clean
df_org = ultra_clean(spark.table("dev.mma_entityresolution.tbl_entityres_ach_org_names_match").withColumnRenamed("sor_id0", "sor_id"), "originator_company_name")
df_rec = ultra_clean(spark.table("dev.mma_entityresolution.tbl_entityres_ach_rec_names_match"), "dest_customer_nm")

# --- STEP 2: VECTOR SEARCH ---
result_schema = StructType([
    StructField("name_clean", StringType(), True),
    StructField("candidates_json", StringType(), True),
    StructField("raw_vector_score", FloatType(), True)
])

def search_vector_worker_v9(iterator):
    import json
    vsc = VectorSearchClient()
    index = vsc.get_index(endpoint_name="talk2db_poc_endpoint", index_name="dev.er_sp_metadata.spg_entity_master_index")
    for pdf in iterator:
        results = []
        for name in pdf['name_clean']:
            try:
                # Top 10 retrieval to ensure accuracy for messy ACH data
                resp = index.similarity_search(query_text=name, columns=["childcompanyname"], num_results=10)
                data = resp.get('result', {}).get('data_array', [])
                candidates = [{"name": str(r[1]), "score": round(float(r[-1]), 4)} for r in data]
                results.append({
                    "name_clean": name,
                    "candidates_json": json.dumps(candidates),
                    "raw_vector_score": candidates[0]['score'] if candidates else 0.0
                })
            except:
                results.append({"name_clean": name, "candidates_json": "[]", "raw_vector_score": 0.0})
        yield pd.DataFrame(results)

# Create registry of unique cleaned names
search_registry = df_org.select("name_clean").union(df_rec.select("name_clean")).distinct()
registry_matches = search_registry.repartition(40).mapInPandas(search_vector_worker_v9, schema=result_schema).cache()

# --- STEP 3: LLM REASONING LAYER ---
prompt_logic = """
format_string(
    "Identify the legal parent entity for: '%s'. Candidates: %s.
     Ignore numbers and transaction junk.
     FORMAT: [MATCH]: <name> | [EXPLANATION]: <reason>", 
    name_clean, candidates_json
)
"""

answer_key = registry_matches.repartition(100).withColumn("llm_raw", 
    F.expr(f"ai_query('databricks-llama-4-maverick', {prompt_logic}, map('max_tokens', '150', 'concurrency', '20'))")
).cache()

# --- STEP 4: FINAL ASSEMBLY (Ensuring all columns are resolved) ---
def finalize_and_save(df_clean, target_table):
    # Ensure we join on name_clean to bring original columns into df_final
    df_final = df_clean.join(registry_matches, on="name_clean", how="left") \
                       .join(answer_key.select("name_clean", "llm_raw"), on="name_clean", how="left")
    
    # Extract AI Answer and Explanation
    df_final = df_final.withColumn("child_name_raw", 
        F.regexp_replace(F.regexp_extract("llm_raw", r"\[MATCH\]:\s*([^|]+)", 1), r"[\*\[\]]", "")) \
                       .withColumn("match_explanation", 
        F.regexp_extract("llm_raw", r"\[EXPLANATION\]:\s*(.*)", 1))

    # Standardize childcompanyname - Fallback to Vector Search if LLM failed
    df_final = df_final.withColumn("childcompanyname", 
        F.when(F.col("child_name_raw") != "", F.col("child_name_raw"))
         .when(F.col("raw_vector_score") > 0.8, F.get_json_object(F.col("candidates_json"), "$[0].name"))
         .otherwise(F.lit("No Clear Match")))

    # THE FINAL SELECTION: Using exact names to avoid 'UNRESOLVED_COLUMN'
    final_cols = ["sor_id", "src_company_name_raw", "childcompanyname", "match_explanation"]
    
    df_final.select(final_cols).write.format("delta").mode("overwrite") \
            .option("overwriteSchema", "true") \
            .saveAsTable(f"dev.mma_entityresolution.{target_table}")
    
    print(f"✅ Success: Updated {target_table}")

# Run the execution
finalize_and_save(df_org, "entity_resolution_ach_origination_llm")
finalize_and_save(df_rec, "entity_resolution_ach_received_llm")
