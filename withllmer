# Updated Schema to hold 3 candidates
result_schema = StructType([
    StructField("src_company_name_normalized", StringType(), True),
    StructField("candidates_json", StringType(), True), # Store all 3 as a JSON string
    StructField("match_confidence_score", FloatType(), True) # Best score for initial filtering
])

def search_vector_worker_top3(iterator):
    import json
    vsc = VectorSearchClient()
    index = vsc.get_index(endpoint_name="talk2db_poc_endpoint", 
                         index_name="dev.er_sp_metadata.spg_entity_master_index")
    for pdf in iterator:
        results = []
        for name in pdf['src_company_name_normalized']:
            try:
                resp = index.similarity_search(query_text=name, 
                                             columns=["childcompanyid", "childcompanyname", "companytypename"], 
                                             num_results=3)
                data = resp.get('result', {}).get('data_array', [])
                
                # Format the 3 results into a list for the LLM
                candidates = []
                for row in data:
                    candidates.append({
                        "id": str(row[0]), 
                        "name": str(row[1]), 
                        "type": str(row[2]), 
                        "score": round(float(row[3]) * 100, 2)
                    })
                
                results.append({
                    "src_company_name_normalized": name,
                    "candidates_json": json.dumps(candidates),
                    "match_confidence_score": candidates[0]['score'] if candidates else 0.0
                })
            except:
                results.append({"src_company_name_normalized": name, "candidates_json": "[]", "match_confidence_score": 0.0})
        yield pd.DataFrame(results)

final_matches_registry = search_registry.repartition(20).mapInPandas(search_vector_worker_top3, schema=result_schema).cache()









# 1. New Prompt Logic: Providing the LLM with a list of options
prompt_logic = """
format_string(
    "Source Name: %s. Here are the Top 3 S&P Candidates: %s. 
     Task: Pick the best match. 
     Return exactly in this format: [Best Name] | [Reasoning]. 
     If none match well, return 'Invalid'.", 
    src_company_name_raw, 
    candidates_json
)
"""

# 2. Run Maverick to decide between the 3
df_final_org = df_final_org.withColumn("llm_decision", 
    F.expr(f"ai_query('databricks-llama-4-maverick', {prompt_logic})")
)

# 3. Split the decision into 'matched_name' and 'match_explanation'
df_final_org = df_final_org.withColumn("match_explanation", F.split("llm_decision", " \| ").getItem(1)) \
                           .withColumn("childcompanyname", F.split("llm_decision", " \| ").getItem(0))

# 4. Final Level Logic
df_final_org = df_final_org.withColumn("match_level", 
    F.when(F.col("llm_decision").contains("Invalid"), "UNMATCHED")
     .when(F.col("match_confidence_score") >= 92, "CHILD")
     .otherwise("PARENT")
)

display(df_final_org.select("src_company_name_raw", "childcompanyname", "match_explanation").limit(10))
