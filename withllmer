import pyspark.sql.functions as F

# 1. Join the Registry (which has candidates_json) to your Main Table
# We use a left join on the normalized name
df_final_org = df_org_clean.join(
    final_matches_registry, 
    on="src_company_name_normalized", 
    how="left"
)

# 2. Define the Maverick Prompt Logic
# This uses the candidates_json column that is now properly joined
prompt_logic = """
format_string(
    "Source Name: %s. Candidates: %s. Task: Pick the best match from the JSON list. 
     Return format: [Best Name] | [Reasoning]. If no match, return 'Invalid | No match'.", 
    src_company_name_raw, 
    candidates_json
)
"""

# 3. Call Llama 4 Maverick
df_final_org = df_final_org.withColumn("llm_decision", 
    F.expr(f"ai_query('databricks-llama-4-maverick', {prompt_logic})")
)

# 4. Parse the LLM's "Split" response into separate columns
# We use split and getItem to extract the Name and the Explanation
df_final_org = df_final_org.withColumn("childcompanyname", F.split("llm_decision", " \| ").getItem(0)) \
                           .withColumn("match_explanation", F.split("llm_decision", " \| ").getItem(1))

# 5. Apply Final Decision Rules
df_final_org = df_final_org.withColumn("match_level", 
    F.when(F.col("llm_decision").contains("Invalid"), "UNMATCHED")
     .when(F.col("match_confidence_score") >= 92, "CHILD")
     .otherwise("PARENT")
)

# Display to verify
display(df_final_org.select(
    "src_company_name_raw", 
    "childcompanyname", 
    "match_explanation", 
    "match_level"
).limit(10))
