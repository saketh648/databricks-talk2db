import pyspark.sql.functions as F

# 1. Join the Registry (which has candidates_json) to your Main Table
df_final_org = df_org_clean.join(
    final_matches_registry, 
    on="src_company_name_normalized", 
    how="left"
)

# 2. Define the Maverick Prompt Logic
prompt_logic = """
format_string(
    "Source Name: %s. Candidates: %s. Task: Pick the best match from the JSON list. 
     Return format: [Best Name] | [Reasoning]. If no match, return 'Invalid | No match'.", 
    src_company_name_raw, 
    candidates_json
)
"""

# 3. Call Llama 4 Maverick
# We use repartition(40) here to force parallelism and speed up the API calls
df_final_org = df_final_org.repartition(40).withColumn("llm_decision", 
    F.expr(f"ai_query('databricks-llama-4-maverick', {prompt_logic})")
)

# 4. Parse the LLM's "Split" response and Apply Decision Rules
df_final_org = df_final_org.withColumn("childcompanyname", F.split("llm_decision", r" \| ").getItem(0)) \
                           .withColumn("match_explanation", F.split("llm_decision", r" \| ").getItem(1)) \
                           .withColumn("match_level", 
                                F.when(F.col("llm_decision").contains("Invalid"), "UNMATCHED")
                                 .when(F.col("match_confidence_score") >= 92, "CHILD")
                                 .otherwise("PARENT"))

# 5. SELECT ONLY THE REQUIRED COLUMNS (The Cleanup Step)
# This prevents the 'all columns' issue you are seeing
final_deliverable_df = df_final_org.select(
    "sor_id", 
    "src_company_name_raw", 
    "role_type",
    "match_level", 
    "match_confidence_score",
    "childcompanyname", 
    "childcompanyid", 
    "companytypename",
    "match_explanation"
)

# 6. Final Write
final_deliverable_df.write.format("delta") \
    .mode("overwrite") \
    .option("overwriteSchema", "true") \
    .saveAsTable("dev.mma_entityresolution.entity_resolution_ach_origination")

print("✅ Success: Clean table created with only the 9 essential columns.")
