# ============================================================
# ENTERPRISE ENTITY RESOLUTION - VECTOR SEARCH FIXED
# ============================================================

import pandas as pd
import pyspark.sql.functions as F
from pyspark.sql.types import *
from databricks.vector_search.client import VectorSearchClient

# ============================================================
# STEP 1: SMARTER CLEANER
# Extracts the REAL brand keyword from ACH transaction strings
# e.g. "#BUE SPLITWISE" → "Splitwise"
#      "#KGP PLAID APP" → "Plaid"
#      "#XUB TESLA PLAID" → "Tesla"
# ============================================================

def enterprise_normalize(df, name_col, id_col="sor_id"):
    return (
        df.withColumn("src_company_name_raw", F.col(name_col))

          # Step A: uppercase for processing
          .withColumn("_upper", F.upper(F.col(name_col)))

          # Step B: strip leading ACH transaction prefix (#BUE, #KGP, 1291RA0923 etc.)
          .withColumn("_stripped",
              F.trim(F.regexp_replace(
                  F.col("_upper"),
                  r"^(#[A-Z0-9]+\s+|[0-9]+[A-Z0-9]*\s+)", ""
              ))
          )

          # Step C: remove known ACH suffixes/noise words that are NOT the brand
          #   "PLAID APP" → "PLAID"  |  "TESLA PLAID" → "TESLA"  |  "ARRIVED HOM" → stripped
          .withColumn("_denoised",
              F.trim(F.regexp_replace(
                  F.col("_stripped"),
                  r"(?i)\b(APP|APPS|PLATFORM|PAYMENT|PAYMENTS|PAY|ARRIVED|HOM|HOME|"
                  r"DEFAULT|LLC|INC|CORP|LTD|SERVICES|S\.P\.A|B\.V|K\.K|"
                  # KEY FIX: "PLAID" is a product of Plaid Inc, not a company itself
                  # "TESLA PLAID" → remove "PLAID" suffix when preceded by another word
                  r"PLAID(?=\s*$))\b",  # remove trailing PLAID only
                  ""
              ))
          )

          # Step D: extract just the FIRST meaningful word as the primary search term
          # "SPLITWISE" → "Splitwise"
          # "DOUBLE GOOD" → "Double Good"  (keep multi-word if no noise)
          .withColumn("name_clean",
              F.initcap(F.trim(F.col("_denoised")))
          )

          # Step E: also keep a single-keyword fallback for retry searches
          .withColumn("name_keyword",
              F.initcap(F.trim(
                  F.regexp_extract(F.col("_denoised"), r"^(\S+)", 1)
              ))
          )

          .drop("_upper", "_stripped", "_denoised")
          .withColumnRenamed(id_col, "sor_id")
    )

spark.catalog.clearCache()

df_org = enterprise_normalize(
    spark.table("dev.mma_entityresolution.tbl_entityres_ach_org_names_match"),
    "originator_company_name", id_col="sor_id0"
)
df_rec = enterprise_normalize(
    spark.table("dev.mma_entityresolution.tbl_entityres_ach_rec_names_match"),
    "dest_customer_nm"
)

# ============================================================
# STEP 2: VECTOR SEARCH - Dual search strategy
# Search 1: full cleaned name  e.g. "Splitwise"
# Search 2: keyword only       e.g. "Splitwise" (fallback if Search 1 weak)
# Merge both, deduplicate, pick best candidates
# ============================================================

result_schema = StructType([
    StructField("name_clean",         StringType(), True),
    StructField("name_keyword",       StringType(), True),
    StructField("candidates_json",    StringType(), True),
    StructField("raw_vector_score",   FloatType(),  True),
    StructField("top_candidate_name", StringType(), True),
])

def is_valid_company_name(name: str) -> bool:
    """Reject pure numeric strings or very short garbage."""
    if not name or len(name.strip()) < 2:
        return False
    # Reject if >70% digits
    digits = sum(c.isdigit() for c in name)
    return (digits / len(name)) < 0.7

def search_vector_worker(iterator):
    import json
    vsc   = VectorSearchClient()
    index = vsc.get_index(
        endpoint_name="talk2db_poc_endpoint",
        index_name="dev.er_sp_metadata.spg_entity_master_index"
    )

    for pdf in iterator:
        results = []

        for _, row in pdf.iterrows():
            name_clean   = row["name_clean"]
            name_keyword = row["name_keyword"]

            try:
                # ── Search 1: full cleaned name
                resp1 = index.similarity_search(
                    query_text=name_clean,
                    columns=["childcompanyname"],
                    num_results=10
                )

                # ── Search 2: keyword only (catches "Splitwise" when full string weak)
                # Only run if keyword differs from full name
                resp2_data = []
                if name_keyword and name_keyword.lower() != name_clean.lower():
                    resp2 = index.similarity_search(
                        query_text=name_keyword,
                        columns=["childcompanyname"],
                        num_results=10
                    )
                    resp2_data = resp2.get("result", {}).get("data_array", [])

                data1 = resp1.get("result", {}).get("data_array", [])

                # ── Merge both result sets, deduplicate by name
                seen    = {}
                keyword = name_keyword.upper() if name_keyword else ""
                full_kw = name_clean.upper()   if name_clean   else ""

                for source_data, weight in [(data1, 1.0), (resp2_data, 0.95)]:
                    for r in source_data:
                        c_name  = str(r[0]).strip()   # index 0 = childcompanyname
                        v_score = float(r[-1])         # last = similarity score

                        if not is_valid_company_name(c_name):
                            continue

                        # Boost: candidate contains our keyword or vice versa
                        c_upper = c_name.upper()
                        if keyword and keyword in c_upper:
                            boost = 1.4   # strong match: "Splitwise" in "Splitwise Inc"
                        elif full_kw and full_kw in c_upper:
                            boost = 1.3
                        elif keyword and c_upper in keyword:
                            boost = 1.2   # reverse containment
                        else:
                            boost = 1.0

                        final_score = round(v_score * 100 * boost * weight, 2)

                        # Keep best score if name seen from both searches
                        if c_name not in seen or final_score > seen[c_name]:
                            seen[c_name] = final_score

                # Sort and take top 5
                processed = [
                    {"name": n, "score": s}
                    for n, s in sorted(seen.items(), key=lambda x: x[1], reverse=True)
                ][:5]

                top = processed[0] if processed else None

                results.append({
                    "name_clean":         name_clean,
                    "name_keyword":       name_keyword,
                    "candidates_json":    json.dumps(processed),
                    "raw_vector_score":   top["score"] if top else 0.0,
                    "top_candidate_name": top["name"]  if top else "",
                })

            except Exception as e:
                results.append({
                    "name_clean":         name_clean,
                    "name_keyword":       name_keyword,
                    "candidates_json":    "[]",
                    "raw_vector_score":   0.0,
                    "top_candidate_name": "",
                })

        yield pd.DataFrame(results)


# Unique name pairs to avoid redundant searches
search_registry = (
    df_org.select("name_clean", "name_keyword")
    .union(df_rec.select("name_clean", "name_keyword"))
    .distinct()
    .filter(
        F.col("name_clean").isNotNull() &
        (F.length(F.trim(F.col("name_clean"))) > 1)
    )
)

registry_matches = (
    search_registry
    .repartition(60)
    .mapInPandas(search_vector_worker, schema=result_schema)
    .cache()
)
registry_matches.count()  # materialise cache

# ============================================================
# STEP 3: LLM - Prompt now explicitly handles PLAID/TESLA cases
# ============================================================

prompt_expr = F.concat_ws("",
    F.lit(
        "You are an ACH payment entity resolution expert.\n"
        "ACH transaction names often contain noise: prefix codes (#BUE, #KGP), "
        "product names (PLAID=payment product, not a company), "
        "or partial brand names.\n\n"
    ),
    F.lit("ORIGINAL ACH NAME: "), F.col("name_clean"),
    F.lit("\nCANDIDATES: "),       F.col("candidates_json"),
    F.lit(
        "\n\nRULES (apply in order):\n"
        "1. PLAID is a payment infrastructure product — the company is 'Plaid Inc'.\n"
        "2. 'TESLA PLAID' refers to Tesla (car), not Plaid the company.\n"
        "3. 'SPLITWISE' → match 'Splitwise Inc' if in candidates.\n"
        "4. Match the candidate whose brand name best represents the ACH input.\n"
        "5. Ignore numeric-only or UUID-like candidates entirely.\n"
        "6. If truly no match, output UNMATCHED.\n\n"
        "RESPOND IN THIS FORMAT ONLY:\n"
        "[MATCH]: <company name or UNMATCHED> | [REASON]: <one sentence>"
    )
)

answer_key = (
    registry_matches
    .withColumn("prompt", prompt_expr)
    .repartition(120)
    .withColumn(
        "llm_raw",
        F.expr(
            "ai_query("
            "  'databricks-llama-4-maverick',"
            "  prompt,"
            "  map('max_tokens', '120', 'temperature', '0')"
            ")"
        )
    )
    .cache()
)
answer_key.count()

# ============================================================
# STEP 4: FINAL ASSEMBLY
# ============================================================

def finalize_and_save(df_clean, target_table):
    df_final = (
        df_clean
        .join(registry_matches, on="name_clean", how="left")
        .join(answer_key.select("name_clean", "llm_raw"), on="name_clean", how="left")
    )

    df_final = (
        df_final
        .withColumn("matched_name_extracted",
            F.trim(F.regexp_replace(
                F.regexp_extract("llm_raw", r"\[MATCH\]:\s*([^|]+)", 1),
                r"[\*\[\]\"']", ""
            ))
        )
        .withColumn("match_explanation",
            F.trim(F.regexp_extract("llm_raw", r"\[REASON\]:\s*(.*)", 1))
        )
    )

    df_final = df_final.withColumn(
        "childcompanyname",
        F.when(
            F.col("matched_name_extracted").isNotNull()
            & (F.length(F.col("matched_name_extracted")) > 1)
            & (F.upper(F.col("matched_name_extracted")) != "UNMATCHED"),
            F.col("matched_name_extracted")
        )
        # Fallback: high-confidence vector hit with valid name
        .when(
            (F.col("raw_vector_score") > 90)
            & F.col("top_candidate_name").isNotNull()
            & (F.length(F.col("top_candidate_name")) > 1)
            & (~F.col("top_candidate_name").rlike(r"^[\d\.\-]+$")),
            F.col("top_candidate_name")
        )
        .otherwise(F.lit("No Clear Match"))
    )

    final_cols = ["sor_id", "src_company_name_raw", "childcompanyname", "match_explanation"]

    (
        df_final.select(final_cols)
        .write.format("delta")
        .mode("overwrite")
        .option("overwriteSchema", "true")
        .saveAsTable(f"dev.mma_entityresolution.{target_table}")
    )
    print(f"✅ Done → dev.mma_entityresolution.{target_table}")


# ── Execute ─────────────────────────────────────────────────
finalize_and_save(df_org, "entity_resolution_ach_origination_llm")
finalize_and_save(df_rec, "entity_resolution_ach_received_llm")
