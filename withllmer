import pyspark.sql.functions as F

# 1. Join the Search Registry to the Main Data
# We bring in 'candidates_json' and 'match_confidence_score'
df_final_org = df_org_clean.join(
    final_matches_registry, 
    on="src_company_name_normalized", 
    how="left"
).repartition(100) # Parallelize for API throughput

# 2. Structured Prompt for Llama 4 Maverick
# We ask it to pick the best 'partyname' (legal name) and explain why
prompt_logic = """
format_string(
    "### Role: Financial Auditor. Task: Select the best legal party match.
     Transaction Name: %s
     S&P Candidates: %s
     
     Instructions: Pick the best Name from the JSON. If no candidate fits, say 'Invalid'.
     Format: NAME: [Selected Name] REASON: [Short Explanation]", 
    src_company_name_raw, 
    candidates_json
)
"""

# 3. Call Llama 4 Maverick
df_final_org = df_final_org.withColumn("llm_raw", 
    F.expr(f"ai_query('databricks-llama-4-maverick', {prompt_logic}, max_tokens => 60, temperature => 0)")
)

# 4. Parse LLM Output and Apply Business Rules
df_final_org = df_final_org.withColumn("childcompanyname", 
    F.regexp_extract("llm_raw", r"NAME:\s*(.*?)\s*REASON:", 1)) \
    .withColumn("match_explanation", 
    F.regexp_extract("llm_raw", r"REASON:\s*(.*)", 1))

# 5. Final Decision Logic for Match Level
# Rules: 
# - Invalid/Null -> UNMATCHED
# - Score >= 92 -> CHILD
# - 80-91 -> PARENT
df_final_org = df_final_org.withColumn("match_level", 
    F.when(F.col("llm_raw").contains("Invalid") | F.col("llm_raw").isNull(), "UNMATCHED")
     .when(F.col("match_confidence_score") >= 92, "CHILD")
     .when(F.col("match_confidence_score") >= 80, "PARENT")
     .otherwise("UNMATCHED")
)

# 6. Select Only the Specific Columns Requested
final_output = df_final_org.select(
    "src_company_name_raw",          # Original messy name
    "src_company_name_normalized",   # The 'Clean' version used for matching
    "childcompanyname",              # AI-selected legal party name
    "match_confidence_score",        # Vector similarity score (0-100)
    "top2_score",                    # Score of the runner-up for ambiguity check
    "match_level",                   # Business classification (CHILD/PARENT/UNMATCHED)
    "match_explanation"              # LLM-generated reason
)

# Display result
display(final_output.limit(10))
