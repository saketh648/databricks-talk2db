import pandas as pd
import pyspark.sql.functions as F
from pyspark.sql.types import *
from databricks.vector_search.client import VectorSearchClient

# --- STEP 0: CLEAR STALE DATA ---
spark.catalog.clearCache() # This forces Spark to re-calculate everything

# --- STEP 1: AGGRESSIVE CLEANING ---
def clean_and_strip_v2(df, name_col):
    # This REGEX handles '#BUE ', '#KZJ ', etc. plus numbers
    return df.withColumn("src_company_name_normalized", 
        F.trim(F.regexp_replace(
            F.regexp_replace(F.upper(F.col(name_col)), r"^#[A-Z0-9]{3,4}\s+", ""), 
            r"[^\w\s]", ""
        ))
    )

df_org = spark.table("dev.mma_entityresolution.tbl_entityres_ach_org_names_match").withColumnRenamed("sor_id0", "sor_id")
df_rec = spark.table("dev.mma_entityresolution.tbl_entityres_ach_rec_names_match")

df_org_clean = clean_and_strip_v2(df_org, "originator_company_name").withColumnRenamed("originator_company_name", "src_company_name_raw")
df_rec_clean = clean_and_strip_v2(df_rec, "dest_customer_nm").withColumnRenamed("dest_customer_nm", "src_company_name_raw")

# --- STEP 2: VECTOR SEARCH (NO CACHE RELIANCE) ---
result_schema = StructType([
    StructField("src_company_name_normalized", StringType(), True),
    StructField("candidates_json", StringType(), True),
    StructField("match_confidence_score", FloatType(), True)
])

def search_vector_worker_final(iterator):
    import json
    vsc = VectorSearchClient()
    index = vsc.get_index(endpoint_name="talk2db_poc_endpoint", index_name="dev.er_sp_metadata.spg_entity_master_index")
    for pdf in iterator:
        results = []
        for name in pdf['src_company_name_normalized']:
            try:
                resp = index.similarity_search(query_text=name, columns=["childcompanyid", "childcompanyname"], num_results=3)
                data = resp.get('result', {}).get('data_array', [])
                candidates = [{"name": str(r[1]), "score": round(float(r[2])*100, 2)} for r in data]
                results.append({
                    "src_company_name_normalized": name,
                    "candidates_json": json.dumps(candidates),
                    "match_confidence_score": candidates[0]['score'] if candidates else 0.0
                })
            except:
                results.append({"src_company_name_normalized": name, "candidates_json": "[]", "match_confidence_score": 0.0})
        yield pd.DataFrame(results)

search_registry = df_org_clean.select("src_company_name_normalized").union(df_rec_clean.select("src_company_name_normalized")).distinct()
registry_matches = search_registry.repartition(40).mapInPandas(search_vector_worker_final, schema=result_schema).cache()

# --- STEP 3: LLM RERANKING WITH EXPLANATION ---
prompt_logic = """
format_string(
    "### TASK: Resolve '%s' using: %s. 
     Rule: Ignore bank prefixes (#BUE, etc). Focus on the core brand.
     Format: MATCHED_NAME: <name> | EXPLANATION: <reason>", 
    src_company_name_normalized, candidates_json
)
"""

uncertain_matches = registry_matches.filter("match_confidence_score >= 70 AND match_confidence_score < 98")

answer_key = uncertain_matches.repartition(100).withColumn("llm_raw", 
    F.expr(f"ai_query('databricks-llama-4-maverick', {prompt_logic}, map('max_tokens', '100', 'concurrency', '20'))")
).cache()

# --- STEP 4: FINAL MAPPING & SELECT ---
def finalize_and_save(df_clean, target_table):
    df_final = df_clean.join(registry_matches, on="src_company_name_normalized", how="left") \
                       .join(answer_key.select("src_company_name_normalized", "llm_raw"), on="src_company_name_normalized", how="left")
    
    # 1. Name Recovery
    df_final = df_final.withColumn("raw_match", 
        F.when(F.col("match_confidence_score") >= 98, F.get_json_object(F.col("candidates_json"), "$[0].name"))
         .when(F.col("match_confidence_score") < 70, F.lit("No Clear Match"))
         .otherwise(F.regexp_extract("llm_raw", r"MATCHED_NAME:\s*([^|]+)", 1)))

    # 2. Canonical Brand Force (The John Deere/Splitwise fix)
    df_final = df_final.withColumn("childcompanyname", 
        F.when(F.col("raw_match").contains("DEERE"), F.lit("Deere & Company"))
         .when(F.col("raw_match").contains("SPLITWISE"), F.lit("Splitwise, Inc."))
         .when(F.col("raw_match").contains("ETSY"), F.lit("Etsy, Inc."))
         .otherwise(F.trim(F.col("raw_match"))))

    # 3. EXPLANATION COLUMN (Must be included here)
    df_final = df_final.withColumn("match_explanation", 
        F.when(F.col("match_confidence_score") >= 98, F.lit("Direct high-confidence vector match."))
         .when(F.col("match_confidence_score") < 70, F.lit("Score below threshold."))
         .otherwise(F.regexp_extract("llm_raw", r"EXPLANATION:\s*(.*)", 1)))

    # 4. WRITE (Explicitly selecting the explanation column)
    final_cols = ["sor_id", "src_company_name_raw", "childcompanyname", "match_explanation"]
    
    df_final.select(final_cols).write.format("delta").mode("overwrite") \
            .option("overwriteSchema", "true") \
            .saveAsTable(f"dev.mma_entityresolution.{target_table}")
    
    print(f"✅ Success: {target_table}")

finalize_and_save(df_org_clean, "entity_resolution_ach_origination_llm")
finalize_and_save(df_rec_clean, "entity_resolution_ach_received_llm")
