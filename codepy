import json
import time
from databricks.vector_search.client import VectorSearchClient

# 1. Setup Client
vsc = VectorSearchClient()
index = vsc.get_index(endpoint_name="talk2db_poc_endpoint", index_name="dev.er_sp_metadata.spg_entity_master_index")

# 2. Get unique names from your existing search_registry
unique_names_list = [row.src_company_name_normalized for row in search_registry.collect()]

# 3. Process loop (Writing to local disk to save Driver RAM)
local_file_path = "/tmp/vector_results_raw.json"
start_time = time.time()

print(f"Starting Vector Search for {len(unique_names_list)} names...")

with open(local_file_path, "w") as f:
    for i, name in enumerate(unique_names_list):
        if i % 250 == 0 and i > 0:
            elapsed = round(time.time() - start_time, 2)
            print(f"Processed {i} / {len(unique_names_list)}... ({elapsed}s)")
        
        try:
            # Search for Top 2 (to check for score gap/ambiguity)
            resp = index.similarity_search(
                query_text=name,
                columns=["child_company_id", "parent_company_id", "primary_business_name"],
                num_results=2
            )
            
            data = resp.get('result', {}).get('data_array', [])
            
            # Structure the result
            res_row = {
                "src_company_name_normalized": str(name),
                "matched_sp_primary_name": str(data[0][2]) if data else None,
                "matched_sp_child_id": str(data[0][0]) if data else None,
                "matched_sp_parent_id": str(data[0][1]) if data else None,
                "match_confidence_score": float(data[0][3] * 100) if data else 0.0,
                "top2_score": float(data[1][3] * 100) if len(data) > 1 else 0.0
            }
            f.write(json.dumps(res_row) + "\n")
            
        except Exception as e:
            print(f"Error at index {i} ({name}): {e}")

print(f"Search Complete! Results saved locally to {local_file_path}")
