from databricks.vector_search.client import VectorSearchClient

# 1. Initialize the Client
vsc = VectorSearchClient()

# 2. Point to your DEV index
# Note: Ensure your workspace has a Vector Search Endpoint running
index = vsc.get_index(
    endpoint_name="your_vector_search_endpoint", # Replace with your actual endpoint name
    index_name="dev.er_sp_metadata.spg_entity_master_index"
)

# 3. Test with a "Tricky" query (The U.S. Bank case)
search_query = "U S BANK ANK" 

results = index.similarity_search(
    query_text=search_query,
    columns=["child_company_name", "parent_company_name", "city", "country"],
    num_results=5
)

# 4. Display as a clean table
import pandas as pd
df_results = pd.DataFrame(
    results['result']['data_array'], 
    columns=["Child Name", "Parent Name", "City", "Country", "Score"]
)

display(df_results)
