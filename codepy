# Add the mandatory 'match_explanation' field for the final audit trail
def finalize_for_storage(df):
    return df.withColumn("match_explanation", 
        F.when(F.col("match_level") == "CHILD", "High Confidence S&P Match (>=92)")
         .when(F.col("match_level") == "PARENT", "Parent/Legal Entity Roll-up (85-91)")
         .otherwise("Unmatched - Review required")
    )

# Prepare the final DataFrames
final_org_output = finalize_for_storage(final_org_results)
final_rec_output = finalize_for_storage(final_rec_results)

# Write to Delta (This should take < 30 seconds once cached)
final_org_output.write.format("delta").mode("overwrite").option("overwriteSchema", "true") \
    .saveAsTable("dev.mma_entityresolution.entity_resolution_ach_origination")

final_rec_output.write.format("delta").mode("overwrite").option("overwriteSchema", "true") \
    .saveAsTable("dev.mma_entityresolution.entity_resolution_ach_received")

print("✅ Tables created: dev.mma_entityresolution.entity_resolution_ach_origination")
print("✅ Tables created: dev.mma_entityresolution.entity_resolution_ach_received")
