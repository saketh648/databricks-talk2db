from databricks.vector_search.client import VectorSearchClient
import pandas as pd
import time

# 1. Initialize Vector Search Client
vsc = VectorSearchClient()
index = vsc.get_index(endpoint_name="talk2db_poc_endpoint", index_name="dev.er_sp_metadata.spg_entity_master_index")

# 2. Get unique names from our Phase 2 search_registry
unique_names_list = [row.src_company_name_normalized for row in search_registry.collect()]

match_results = []
start_time = time.time()

print(f"Starting Vector Search for {len(unique_names_list)} unique candidates...")

# 3. Execution Loop
# Note: We query Top 2 to handle the 'Generic/Ambiguous' check from Step 6
for i, name in enumerate(unique_names_list):
    if i % 500 == 0 and i > 0:
        print(f"Processed {i} names... (Elapsed: {round(time.time() - start_time, 2)}s)")
    
    try:
        search_resp = index.similarity_search(
            query_text=name,
            columns=["child_company_id", "parent_company_id", "primary_business_name"],
            num_results=2
        )
        
        # Extract data
        data = search_resp.get('result', {}).get('data_array', [])
        
        if data:
            top1 = data[0]
            # Use a dummy for top2 if only 1 result returned
            top2 = data[1] if len(data) > 1 else [None, None, None, 0.0]
            
            match_results.append({
                "src_company_name_normalized": name,
                "matched_sp_primary_name": top1[2],
                "matched_sp_child_id": top1[0],
                "matched_sp_parent_id": top1[1],
                "match_confidence_score": float(top1[3]) * 100,
                "top2_score": float(top2[3]) * 100
            })
        else:
            match_results.append({
                "src_company_name_normalized": name,
                "matched_sp_primary_name": None,
                "matched_sp_child_id": None,
                "matched_sp_parent_id": None,
                "match_confidence_score": 0.0,
                "top2_score": 0.0
            })
            
    except Exception as e:
        print(f"Error at index {i} for name '{name}': {e}")
        continue

# 4. Convert Results to Spark DataFrame
results_pd = pd.DataFrame(match_results)
results_df = spark.createDataFrame(results_pd)

# 5. Apply Step 6 Decision Rules
# Thresholds: 92 (CHILD), 85 (PARENT)
# Ambiguity Rule: (top1 - top2) < 3 points
final_matches_registry = results_df.withColumn("match_level", 
    F.when(
        (F.col("match_confidence_score") >= 92) & 
        ((F.col("match_confidence_score") - F.col("top2_score")) >= 3), 
        "CHILD"
    )
    .when(F.col("match_confidence_score") >= 85, "PARENT")
    .otherwise("UNMATCHED")
).withColumn("match_method", F.lit("VECTOR_SEARCH_COSINE"))

# 6. Final Join back to your 10,000 Source Rows
final_org_results = df_org_prepped.join(final_matches_registry, on="src_company_name_normalized", how="left")
final_rec_results = df_rec_prepped.join(final_matches_registry, on="src_company_name_normalized", how="left")

print(f"Phase 3 Complete. Total matches processed: {len(match_results)}")
display(final_org_results.limit(10))
