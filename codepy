from pyspark.sql import functions as F

# 1. Configuration & Paths
SOURCE_TABLE = "talk2db_poc.data_layer.transaction_detail_ach"
OUTPUT_TABLE = "talk2db_poc.data_layer.ach_orig_candidates_prepped"

# 2. Define the Cleaning Pattern (The "Janitor")
# We remove special characters and common banking noise, but keep the words
# so the LLM and Vector Search have the full context of names like "FRANCHISE TAX BD"
garbage_regex = r"([^\w\s]|\b(ACH|PMT|PAY|WEB|PPD|CCD|CTX|STORE|STE|STREET|SUITE)\b)"

# 3. Load and Aggregate (The "Funnel" for Scale)
# We group by Name + Routing so we only solve "FRANCHISE TAX BD" once
raw_df = spark.table(SOURCE_TABLE)

df_agg = raw_df.groupBy("originator_company_name", "originating_rt_nbr") \
    .agg(
        F.count("*").alias("txn_count"),
        F.sum("dest_transaction_amt").alias("total_txn_amt"),
        F.first("dest_tr_nbr").alias("anchor_id") # Keeping a non-null ID for audit
    )

# 4. Apply Light Cleaning
# This reveals the "Entity Signal" without losing the meaning of abbreviations
df_cleaned = df_agg \
    .withColumn("src_name_upper", F.upper(F.col("originator_company_name"))) \
    .withColumn("src_name_clean", F.regexp_replace("src_name_upper", garbage_regex, " ")) \
    .withColumn("src_name_final", F.trim(F.regexp_replace("src_name_clean", r"\s+", " "))) \
    .select(
        "anchor_id",
        "originator_company_name", # Raw name for the "Conversation"
        "src_name_final",          # Clean name for the "Librarian"
        "originating_rt_nbr",
        "txn_count",
        "total_txn_amt"
    )

# 5. Save the Progress
df_cleaned.write.mode("overwrite").saveAsTable(OUTPUT_TABLE)

print(f"Success! {SOURCE_TABLE} has been aggregated and cleaned.")
print(f"Results stored in: {OUTPUT_TABLE}")
